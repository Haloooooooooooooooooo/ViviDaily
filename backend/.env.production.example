# Backend
API_PORT=3102
CORS_ALLOW_ORIGIN=https://your-frontend-domain.vercel.app

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# News + AI
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Notion export mode
NOTION_EXPORT_MODE=user_oauth

# Notion OAuth (required in user_oauth mode)
NOTION_CLIENT_ID=your_notion_client_id
NOTION_CLIENT_SECRET=your_notion_client_secret
NOTION_REDIRECT_URI=https://api.your-domain.com/api/notion/oauth/callback
FRONTEND_URL=https://your-frontend-domain.vercel.app
NOTION_OAUTH_TABLE=user_notion_connections

# Optional fallback (shared mode only)
NOTION_API_KEY=
NOTION_DATABASE_ID=

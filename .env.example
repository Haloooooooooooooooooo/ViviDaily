# Notion config
NOTION_API_KEY=secret_xxx
NOTION_DATABASE_ID=xxx

# AI config
AI_API_KEY=sk-xxx
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# Fixed backend API port
API_PORT=3102

# CORS, for production set your frontend domain, comma separated if multiple.
# Example: CORS_ALLOW_ORIGIN=https://your-domain.com,https://www.your-domain.com
CORS_ALLOW_ORIGIN=http://127.0.0.1:3000

# Frontend runtime
VITE_API_BASE_URL=http://127.0.0.1:3102
VITE_DEV_PORT=3000
